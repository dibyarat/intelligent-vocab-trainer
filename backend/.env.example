# Server Configuration
PORT=8080
NODE_ENV=production

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json

# Firebase Admin SDK (Firestore + FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloud Vision API
GOOGLE_VISION_API_KEY=your-cloud-vision-api-key

# Free Dictionary API (no key needed, but for config)
DICTIONARY_API_BASE_URL=https://api.dictionaryapi.dev/api/v2/entries/en

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000

# Notification Cron Schedule (daily at 9 AM)
NOTIFICATION_CRON_SCHEDULE=0 9 * * *
